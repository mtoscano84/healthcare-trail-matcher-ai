FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
RUN pip install google-adk[toolbox] requests

# Copy agent code
COPY src src

# Expose port for adk web
EXPOSE 8000

# Run the agent using adk web pointing to the src directory
CMD ["adk", "web", "src"]
